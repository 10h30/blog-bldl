---
export interface Props {
  src: string;
  alt: string;
  class?: string;
  fetchpriority?: "high" | "low" | "auto";
  loading?: "lazy" | "eager";
}

const { src, alt, class: className, fetchpriority, loading } = Astro.props;
---

<picture>
  <img
    src={src}
    alt={alt}
    class={className}
    fetchpriority={fetchpriority}
    loading={loading}
  />
</picture>
